{
  "name": "mf-overlays-lib",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:development": "ng build lib --configuration development",
    "build:production": "ng build lib --configuration production",
    "watch": "ng build --watch --configuration development",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "storybook": "ng run storybook:storybook",
    "storybook:build": "ng run storybook:build-storybook",
    "test-storybook": "test-storybook --url http://localhost:6006 --config-dir projects/storybook/.storybook",
    "storybook:test": "npm run storybook:build && start-server-and-test 'cd dist/storybook-static && python3 -m http.server 6006' http://localhost:6006 'test-storybook --url http://localhost:6006 --config-dir projects/storybook/.storybook'"
  },
  "dependencies": {
    "@angular/common": "19.2.21",
    "@angular/compiler": "19.2.21",
    "@angular/core": "19.2.21",
    "@angular/forms": "19.2.21",
    "@angular/platform-browser": "19.2.21",
    "@angular/platform-browser-dynamic": "19.2.21",
    "rxjs": "~7.8.2",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "19.2.21",
    "@angular/cli": "19.2.21",
    "@angular/compiler-cli": "19.2.21",
    "@ngx-translate/core": "^16.0.4",
    "@playwright/test": "^1.61.0",
    "@storybook/addon-a11y": "10.4.5",
    "@storybook/addon-docs": "10.4.5",
    "@storybook/addon-onboarding": "10.4.5",
    "@storybook/angular": "10.4.5",
    "@storybook/test-runner": "^0.24.4",
    "@types/jest": "^29.5.14",
    "jest": "^29.7.0",
    "jest-preset-angular": "^14.6.2",
    "ng-packagr": "^19.2.0",
    "start-server-and-test": "^3.0.11",
    "storybook": "10.4.5",
    "ts-node": "^10.9.2",
    "typescript": "~5.8.3"
  }
}
